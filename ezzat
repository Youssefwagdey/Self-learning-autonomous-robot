/*تاني كود هيئه المحركات وحساس الالتراسونيك وحلقه الاستقبال من ال   (ESP32)
ARDUINO MEGA OR MEGA2560*/
const int trigpin =7;
  const int echopin =8;
  const int IN1 = 5;
  const int IN2 =4;
  const int IN3 =3;
  const int IN4 =2;
   void setup(){
    Serial.begin (112500);
    pinMode(IN1, OUTPUT);
    pinMode(IN2, OUTPUT);
    pinMode(IN3, OUTPUT);
    pinMode(IN4, OUTPUT);
    stoprobot();
    pinMode (trigpin, OUTPUT);
    pinMode (echopin , INPUT);
    digitalWrite (trigpin , LOW);
    Serial.println("core system success");
    Serial.println("motor safe  sensor ready ");
   }
         void stoprobot(){
         digitalWrite(IN1,LOW);
         digitalWrite(IN2,LOW);
         digitalWrite(IN3,LOW);
         digitalWrite(IN4,LOW);
    Serial.println ("system check; motor set to low");
    }   void loop (){}


